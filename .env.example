# --- Database ---
# Production (Neon Postgres): use the POOLED connection string for DATABASE_URL,
# and the DIRECT (non-pooled) string for DIRECT_URL, which Prisma uses for
# migrations. Both are in your Neon dashboard.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require"

# --- Auth.js ---
# Secret used to sign/encrypt the session cookie. Generate one with:
#   npx auth secret
# Never commit the real value.
AUTH_SECRET="replace-with-a-strong-random-string"
