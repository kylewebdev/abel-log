# --- Database ---
# Local PostgreSQL defaults. Replace both values with the appropriate pooled and
# direct URLs when using a hosted PostgreSQL provider.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/abel_log?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/abel_log?schema=public"

# --- Auth.js ---
# Secret used to sign/encrypt the session cookie. Generate one with:
#   npx auth secret
# Never commit the real value.
AUTH_SECRET="replace-with-a-strong-random-string"

# --- Local demo seed ---
# The seed refuses to run unless this is explicitly enabled, and always refuses
# when NODE_ENV or VERCEL_ENV is production.
ENABLE_DEMO_SEED="false"

# Optional passwords used only when each demo account is first created. If a
# value is omitted, the seed generates and prints a random password once.
# SEED_PASSWORD_MANAGEMENT=""
# SEED_PASSWORD_TEAM_A=""
# SEED_PASSWORD_TEAM_B=""
# SEED_PASSWORD_TEAM_C=""
# SEED_PASSWORD_TEAM_D=""
# SEED_PASSWORD_TEAM_E=""
